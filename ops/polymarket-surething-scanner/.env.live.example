# Rename to .env.live before enabling live mode.
# The scanner will refuse live trading unless BOTH are true:
#   1) config.yaml -> live.enabled: true
#   2) POLYMARKET_LIVE_ENABLED=true in this file (or shell env)

POLYMARKET_LIVE_ENABLED=false
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_DATA_API_BASE=https://data-api.polymarket.com
POLYMARKET_CHAIN_ID=137

# Required for authenticated live trading
POLYMARKET_PRIVATE_KEY=
# Optional explicit profile/proxy wallet used by Data API. If omitted, the code falls back to funder or signer address.
POLYMARKET_PROFILE_ADDRESS=

# Required for proxy/email/Magic wallet flows (signature_type 1/2)
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=0

# Optional. If omitted, the code will derive API creds from the private key.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
